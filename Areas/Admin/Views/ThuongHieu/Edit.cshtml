@model WebBanGiay.Models.ThuongHieu
@{
    ViewData["Title"] = "Sửa thương hiệu";
}
<link rel="stylesheet" href="~/css/Admin/ThuongHieu/Edit.css" />

<div class="card border-0 shadow-sm th-card">
    <div class="card-body p-0">
        <div class="th-header px-4 py-3 border-bottom d-flex align-items-center justify-content-between">
            <div>
                <div class="th-title">Sửa thương hiệu</div>
                <div class="th-subtitle">Cập nhật thông tin thương hiệu</div>
            </div>
            <a asp-area="Admin" asp-controller="ThuongHieu" asp-action="Index"
               class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>

        <form asp-area="Admin" asp-controller="ThuongHieu" asp-action="Edit" asp-route-id="@Model.MaThuongHieu" method="post"
              class="th-form px-4 py-4">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="th-section">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Mã thương hiệu</label>
                        <input asp-for="MaThuongHieu" class="form-control" readonly />
                    </div>

                    <div class="col-md-8">
                        <label class="form-label">Tên thương hiệu</label>
                        <input asp-for="TenThuongHieu" class="form-control" placeholder="Nhập tên thương hiệu" />
                        <span asp-validation-for="TenThuongHieu" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success d-flex align-items-center gap-2 px-3">
                    <i class="fa-solid fa-save"></i>
                    <span>Lưu</span>
                </button>
                <a asp-area="Admin" asp-controller="ThuongHieu" asp-action="Index"
                   class="btn btn-outline-secondary d-flex align-items-center gap-2 px-3">
                    <i class="fa-solid fa-xmark"></i>
                    <span>Hủy</span>
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/Admin/ThuongHieu/Edit.js" asp-append-version="true"></script>
}
