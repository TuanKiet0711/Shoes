@model IEnumerable<WebBanGiay.Models.TaiKhoan>
@{
    ViewData["Title"] = "Tài khoản";
}
<link rel="stylesheet" href="~/css/Admin/TaiKhoan/Index.css" />

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">

        <form method="get" class="px-4 py-3 border-bottom">
            <div class="row g-2 align-items-end">

                <div class="col-md-3">
                    <label class="form-label small text-muted">Tìm kiếm</label>
                    <div class="input-group">
                        <button type="submit" class="input-group-text bg-light">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                        <input type="text" name="q" value="@ViewBag.Query" class="form-control"
                               placeholder="Mã tài khoản / họ tên / email / sđt" />
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label small text-muted">Vai trò</label>
                    <select class="form-select" name="role">
                        <option value="">Tất cả</option>
                        <option value="Admin" selected="@(string.Equals(ViewBag.Role as string, "Admin", StringComparison.OrdinalIgnoreCase))">Admin</option>
                        <option value="TaiXe" selected="@(string.Equals(ViewBag.Role as string, "TaiXe", StringComparison.OrdinalIgnoreCase))">Tài xế</option>
                        <option value="KhachHang" selected="@(string.Equals(ViewBag.Role as string, "KhachHang", StringComparison.OrdinalIgnoreCase))">Khách hàng</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small text-muted">Trạng thái</label>
                    <select class="form-select" name="status">
                        <option value="">Tất cả</option>
                        <option value="HoatDong" selected="@(string.Equals(ViewBag.Status as string, "HoatDong", StringComparison.OrdinalIgnoreCase))">Hoạt động</option>
                        <option value="Khoa" selected="@(string.Equals(ViewBag.Status as string, "Khoa", StringComparison.OrdinalIgnoreCase))">Khóa</option>
                    </select>
                </div>

                <div class="col-md-3 d-flex align-items-end justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary d-flex align-items-center gap-2 px-3">
                        <i class="fa-solid fa-filter"></i>
                        <span>Lọc</span>
                    </button>

                    <a asp-area="Admin" asp-controller="TaiKhoan" asp-action="Index"
                       class="btn btn-outline-secondary d-flex align-items-center gap-2 px-3">
                        <i class="fa-solid fa-rotate-left"></i>
                        <span>Hủy</span>
                    </a>

                    <a asp-area="Admin" asp-controller="TaiKhoan" asp-action="Create"
                       class="btn btn-success d-flex align-items-center gap-2 px-3">
                        <i class="fa-solid fa-plus"></i>
                        <span>Thêm</span>
                    </a>
                </div>
            </div>
        </form>

        <div class="px-4 py-2 text-muted small border-bottom">
            Tổng: <b>@(Model?.Count() ?? 0)</b> tài khoản
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4" style="width:160px;">Mã tài khoản</th>
                        <th>Họ và tên</th>
                        <th>Email</th>
                        <th style="width:140px;">Vai trò</th>
                        <th style="width:140px;">Trạng thái</th>
                        <th class="text-center pe-4" style="width:160px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var tk in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">@tk.MaTaiKhoan</td>
                                <td class="fw-semibold">@tk.HoTen</td>
                                <td>@tk.Email</td>
                                <td>
                                    @{
                                        var roleLabel = string.Equals(tk.VaiTro, "Admin", StringComparison.OrdinalIgnoreCase)
                                            ? "Admin"
                                            : (string.Equals(tk.VaiTro, "TaiXe", StringComparison.OrdinalIgnoreCase) ? "Tài xế" : "Khách hàng");
                                        var roleBadge = string.Equals(tk.VaiTro, "Admin", StringComparison.OrdinalIgnoreCase)
                                            ? "danger"
                                            : (string.Equals(tk.VaiTro, "TaiXe", StringComparison.OrdinalIgnoreCase) ? "warning" : "primary");
                                    }
                                    <span class="badge bg-@roleBadge">@roleLabel</span>
                                </td>
                                <td>
                                    <span class="badge bg-@(string.Equals(tk.TrangThai, "Khoa", StringComparison.OrdinalIgnoreCase) ? "secondary" : "success")">
                                        @(string.Equals(tk.TrangThai, "Khoa", StringComparison.OrdinalIgnoreCase) ? "Khóa" : "Hoạt động")
                                    </span>
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a class="btn btn-outline-secondary btn-sm"
                                           asp-area="Admin" asp-controller="TaiKhoan" asp-action="Details" asp-route-id="@tk.MaTaiKhoan">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <a class="btn btn-outline-primary btn-sm"
                                           asp-area="Admin" asp-controller="TaiKhoan" asp-action="Edit" asp-route-id="@tk.MaTaiKhoan">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a class="btn btn-outline-danger btn-sm"
                                           asp-area="Admin" asp-controller="TaiKhoan" asp-action="Delete" asp-route-id="@tk.MaTaiKhoan">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">Không có tài khoản nào</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/Admin/TaiKhoan/Index.js" asp-append-version="true"></script>
}
