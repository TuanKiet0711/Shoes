@model WebBanGiay.Models.BienTheSanPham
@{
    ViewData["Title"] = "Sửa biến thể";
    var sanPhamList = ViewBag.SanPhamList as List<WebBanGiay.Models.SanPham>;
    var selectedMaSanPham = ViewBag.MaSanPham as string;
}
<link rel="stylesheet" href="~/css/Admin/BienThe/Create.css" />
<div class="bt-page">
<div class="card border-0 shadow-sm bt-form bt-form--hero">
    <div class="card-header bt-hero">
        <div class="bt-hero-content">
            <div class="bt-hero-left">
                <span class="bt-icon">
                    <i class="fa-solid fa-pen"></i>
                </span>
                <div>
                    <div class="bt-title">Sửa biến thể</div>
                    <div class="bt-subtitle">Cập nhật size, màu cho sản phẩm</div>
                </div>
            </div>

            <a asp-area="Admin" asp-controller="BienTheSanPham" asp-action="Index"
               class="btn btn-light btn-sm bt-back">
                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="card-body">
        <form asp-area="Admin" asp-controller="BienTheSanPham" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="id" value="@Model.MaBienThe" />

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="bt-section">
                <div class="row g-3 bt-stack">

                    <div class="col-12">
                        <label class="form-label">Mã biến thể</label>
                        <input asp-for="MaBienThe" class="form-control" readonly />
                        <span asp-validation-for="MaBienThe" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Sản phẩm</label>
                       @{
    var currentMaSanPham = (Model?.MaSanPham ?? selectedMaSanPham ?? "").ToString();
    var currentLabel = "-- Chọn sản phẩm --";

    if (sanPhamList != null && !string.IsNullOrEmpty(currentMaSanPham))
    {
        var sp = sanPhamList.FirstOrDefault(x => x.MaSanPham == currentMaSanPham);
        if (sp != null) currentLabel = sp.TenSanPham;
    }
}

<div class="dropdown w-100 dd-wrap">
    <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center"
            type="button"
            data-bs-toggle="dropdown"
            data-dd="MaSanPham"
            aria-expanded="false">
        <span class="dd-label">@currentLabel</span>
    </button>

    <div class="dropdown-menu w-100 p-2 shadow-sm dd-menu">
        <input type="text"
               class="form-control form-control-sm mb-2 dd-search"
               placeholder="Gõ để tìm sản phẩm..."
               autocomplete="off" />

        <div class="dd-list">
            <button type="button"
                    class="dropdown-item dd-item"
                    data-value=""
                    data-label="-- Chọn sản phẩm --">
                -- Chọn sản phẩm --
            </button>

            @if (sanPhamList != null)
            {
                foreach (var sp in sanPhamList)
                {
                    var active = sp.MaSanPham == currentMaSanPham ? "active" : "";
                    <button type="button"
                            class="dropdown-item dd-item @active"
                            data-value="@sp.MaSanPham"
                            data-label="@sp.TenSanPham">
                        @sp.TenSanPham
                    </button>
                }
            }
        </div>
    </div>

    <input asp-for="MaSanPham"
           type="hidden"
           value="@currentMaSanPham"
           data-dd-hidden="MaSanPham" />
</div>

<span asp-validation-for="MaSanPham" class="text-danger small"></span>

                    </div>

                    <div class="col-12">
                        <label class="form-label">Size</label>
                        <input asp-for="Size" type="number" min="1" class="form-control"
                               placeholder="Nhập size" />
                        <span asp-validation-for="Size" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Màu sắc</label>
                        <input asp-for="MauSac" class="form-control"
                               placeholder="Nhập màu sắc" />
                        <span asp-validation-for="MauSac" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Số lượng</label>
                        <input asp-for="SoLuong" type="number" min="0" class="form-control"
                               placeholder="Nhập số lượng" />
                        <span asp-validation-for="SoLuong" class="text-danger small"></span>
                    </div>

                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success btn-glow bt-primary">
                    <i class="fa-solid fa-save me-1"></i> Lưu
                </button>
                <a asp-area="Admin" asp-controller="BienTheSanPham" asp-action="Index"
                   class="btn btn-outline-secondary">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/Admin/BienThe/Create.js" asp-append-version="true"></script>
}
