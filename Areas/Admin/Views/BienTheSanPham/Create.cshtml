@model WebBanGiay.Models.BienTheSanPham
@{
    ViewData["Title"] = "Thêm biến thể";
    var sanPhamList = ViewBag.SanPhamList as List<WebBanGiay.Models.SanPham>;
    var selectedMaSanPham = ViewBag.MaSanPham as string;
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-semibold d-flex align-items-center justify-content-between">
        <div>
            <i class="fa-solid fa-plus me-2"></i> Thêm biến thể
        </div>

        <a asp-area="Admin" asp-controller="BienTheSanPham" asp-action="Index"
           class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="card-body">
        <form asp-area="Admin" asp-controller="BienTheSanPham" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">

                <div class="col-md-4">
                    <label class="form-label">Mã biến thể</label>
                    <input asp-for="MaBienThe" class="form-control"
                           placeholder="Ví dụ: BT001, AF1-WHITE-42" />
                </div>

                <div class="col-md-8">
                    <label class="form-label">Sản phẩm</label>
                    <select asp-for="MaSanPham" class="form-select">
                        <option value="">-- Chọn sản phẩm --</option>
                        @if (sanPhamList != null)
                        {
                            foreach (var sp in sanPhamList)
                            {
                                var isSelected = (Model?.MaSanPham == sp.MaSanPham) || (selectedMaSanPham == sp.MaSanPham);
                                <option value="@sp.MaSanPham" selected="@isSelected">
                                    @sp.TenSanPham
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Size</label>
                    <input asp-for="Size" type="number" min="1" class="form-control"
                           placeholder="Ví dụ: 39, 40, 41, 42..." />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Màu sắc</label>
                    <input asp-for="MauSac" class="form-control"
                           placeholder="Ví dụ: Trắng, Đen, Xanh..." />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Số lượng</label>
                    <input asp-for="SoLuong" type="number" min="0" class="form-control"
                           placeholder="Ví dụ: 10" />
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-save me-1"></i> Lưu
                </button>
                <a asp-area="Admin" asp-controller="BienTheSanPham" asp-action="Index"
                   class="btn btn-outline-secondary">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>
