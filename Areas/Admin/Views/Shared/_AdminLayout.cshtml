<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin LeeShoes</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>
        :root {
            --sidebar-bg: #0f172a;
            --sidebar-hover: #1e293b;
            --primary-color: #3b82f6;
            --text-gray: #e2e8f0;      /* ⬅ sáng hơn */
            --text-sub: #cbd5f5;       /* ⬅ submenu */
            --label-gray: #94a3b8;     /* ⬅ label */
            --topbar-height: 60px;
            --sidebar-width: 240px;
        }

        * { box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body { margin: 0; background: #f8fafc; overflow-x: hidden; }

        .admin-root { display: flex; min-height: 100vh; }

        /* SIDEBAR */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            color: #fff;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        .logo {
            padding: 18px 20px;
            font-size: 20px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
            background: #1e293b;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .menu-container {
            flex: 1;
            overflow-y: auto;
            padding: 15px 10px;
            scrollbar-width: none;
        }
        .menu-container::-webkit-scrollbar { display: none; }

        .menu-label {
            color: var(--label-gray);
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 18px 0 8px 12px;
        }

        .menu { list-style: none; padding: 0; margin: 0; }
        .menu li { margin-bottom: 2px; }

        .menu li a {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 12px;
            color: var(--text-gray);
            text-decoration: none;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.2s ease;
        }

        .menu li a:hover {
            background: var(--sidebar-hover);
            color: #ffffff;
        }

        .menu li.active > a {
            background: var(--primary-color);
            color: #ffffff;
            box-shadow: 0 4px 12px rgba(59,130,246,0.35);
        }

        .menu-left { display: flex; align-items: center; gap: 10px; }
        .menu-left i { width: 18px; font-size: 16px; text-align: center; }

        .menu-arrow {
            font-size: 9px;
            color: #e5e7eb;
            transition: transform 0.3s;
        }

        /* SUBMENU */
        .submenu {
            list-style: none;
            padding: 4px 0;
            margin: 4px 0;
            background: rgba(255,255,255,0.04);
            border-radius: 8px;
            display: none;
        }

        .submenu li a {
            padding: 8px 12px 8px 40px;
            font-size: 13px;
            color: var(--text-sub);
        }

        .submenu li a:hover {
            background: var(--sidebar-hover);
            color: #ffffff;
        }

        .has-sub.open .submenu { display: block; }
        .has-sub.open .menu-arrow { transform: rotate(180deg); }

        /* MAIN */
        .main {
            flex: 1;
            margin-left: var(--sidebar-width);
            display: flex;
            flex-direction: column;
        }

        .topbar {
            height: var(--topbar-height);
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            padding: 0 25px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .user-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px;
            border-radius: 8px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            cursor: pointer;
            font-size: 14px;
        }

        .user-btn img {
            width: 28px;
            height: 28px;
            border-radius: 6px;
        }

        .user-dropdown { position: relative; }

        .user-menu {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            background: #ffffff;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
            min-width: 180px;
            padding: 6px;
            display: none;
        }

        .user-menu a {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            text-decoration: none;
            color: #334155;
            font-size: 13px;
            border-radius: 6px;
        }

        .user-menu a:hover {
            background: #f1f5f9;
            color: var(--primary-color);
        }

        .user-dropdown.open .user-menu { display: block; }

        .content { padding: 20px; }
    </style>
</head>
<body>

<div class="admin-root">
    <aside class="sidebar">
        <div class="logo">
            <i class="fa-solid fa-bolt text-primary"></i>
            <span>LeeShoes</span>
        </div>

        <div class="menu-container">
            <div class="menu-label">Tổng quan</div>
            <ul class="menu">
                <li class="active">
                    <a asp-area="Admin" asp-controller="Home" asp-action="Index">
                        <div class="menu-left"><i class="fa-solid fa-chart-pie"></i><span>Dashboard</span></div>
                    </a>
                </li>
            </ul>

            <div class="menu-label">Quản lý kho</div>
            <ul class="menu">
                <li class="has-sub">
                    <a href="javascript:void(0)" onclick="toggleMenu(this)">
                        <div class="menu-left"><i class="fa-solid fa-box"></i><span>Sản phẩm</span></div>
                        <i class="fa-solid fa-chevron-down menu-arrow"></i>
                    </a>
                    <ul class="submenu">
                        <li><a href="#">Danh sách</a></li>
                        <li><a href="#">Biến thể</a></li>
                        <li><a href="#">Hình ảnh</a></li>
                    </ul>
                </li>
                <li><a href="#"><div class="menu-left"><i class="fa-solid fa-layer-group"></i><span>Danh mục</span></div></a></li>
                <li><a href="#"><div class="menu-left"><i class="fa-solid fa-copyright"></i><span>Thương hiệu</span></div></a></li>
            </ul>

            <div class="menu-label">Đơn hàng</div>
            <ul class="menu">
                <li><a href="#"><div class="menu-left"><i class="fa-solid fa-receipt"></i><span>Đơn hàng mới</span></div></a></li>
                <li><a href="#"><div class="menu-left"><i class="fa-solid fa-ticket"></i><span>Mã giảm giá</span></div></a></li>
            </ul>

            <div class="menu-label">Giao nhận</div>
            <ul class="menu">
                <li class="has-sub">
                    <a href="javascript:void(0)" onclick="toggleMenu(this)">
                        <div class="menu-left"><i class="fa-solid fa-truck-fast"></i><span>Tài xế</span></div>
                        <i class="fa-solid fa-chevron-down menu-arrow"></i>
                    </a>
                    <ul class="submenu">
                        <li><a href="#">Đội ngũ</a></li>
                        <li><a href="#">Phân công</a></li>
                    </ul>
                </li>
            </ul>

            <div class="menu-label">Hệ thống</div>
            <ul class="menu">
                <li><a href="#"><div class="menu-left"><i class="fa-solid fa-user-group"></i><span>Tài khoản</span></div></a></li>
                <li><a href="/"><div class="menu-left"><i class="fa-solid fa-globe"></i><span>Website</span></div></a></li>
            </ul>
        </div>
    </aside>

    <div class="main">
        <header class="topbar">
            <div class="title">@ViewData["Title"]</div>

            <div class="user-dropdown">
                <div class="user-btn" onclick="toggleUserMenu(this)">
                    <img src="https://ui-avatars.com/api/?name=Admin&background=3b82f6&color=fff">
                    <span class="fw-semibold">Quản trị viên</span>
                    <i class="fa-solid fa-angle-down opacity-50"></i>
                </div>
                <div class="user-menu">
                    <a href="#"><i class="fa-solid fa-user-circle"></i> Tài khoản</a>
                    <a href="#" class="text-danger"><i class="fa-solid fa-sign-out-alt"></i> Đăng xuất</a>
                </div>
            </div>
        </header>

        <main class="content">
            @RenderBody()
        </main>
    </div>
</div>

<script>
    function toggleMenu(el) {
        el.parentElement.classList.toggle("open");
    }
    function toggleUserMenu(el) {
        el.parentElement.classList.toggle("open");
    }
    window.onclick = function (e) {
        if (!e.target.closest('.user-dropdown')) {
            document.querySelector('.user-dropdown')?.classList.remove('open');
        }
    }
</script>
</body>
</html>
