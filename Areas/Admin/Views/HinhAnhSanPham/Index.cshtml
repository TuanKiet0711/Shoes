@model IEnumerable<WebBanGiay.Models.HinhAnhSanPham>
@{
    ViewData["Title"] = "Hình ảnh sản phẩm";
    var sanPhamList = ViewBag.SanPhamList as List<WebBanGiay.Models.SanPham>;

    var selectedMaSanPham = (ViewBag.MaSanPham ?? "").ToString();
    var selectedTenSanPham = "-- Tất cả --";
    if (sanPhamList != null && !string.IsNullOrEmpty(selectedMaSanPham))
    {
        var spSelected = sanPhamList.FirstOrDefault(x => x.MaSanPham == selectedMaSanPham);
        if (spSelected != null) selectedTenSanPham = spSelected.TenSanPham;
    }

    bool? laAnhDaiDien = ViewBag.LaAnhDaiDien as bool?;
    var laAnhLabel = "-- Tất cả --";
    if (laAnhDaiDien == true) laAnhLabel = "Có";
    if (laAnhDaiDien == false) laAnhLabel = "Không";
}

<link rel="stylesheet" href="~/css/Admin/HinhAnh/Index.css" />

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">

        <form method="get" class="px-4 py-3 border-bottom">
            <div class="row g-2 align-items-end">

                <div class="col-md-3">
                    <label class="form-label small text-muted">Tìm kiếm</label>
                    <div class="input-group">
                        <button type="submit" class="input-group-text bg-light">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                        <input type="text"
                               name="q"
                               value="@ViewBag.Query"
                               class="form-control"
                               placeholder="Mã ảnh / mã SP / tên SP" />
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label small text-muted">Sản phẩm</label>

                    <div class="dropdown w-100 dd-wrap">
                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center"
                                type="button"
                                data-bs-toggle="dropdown"
                                data-dd="maSanPham"
                                aria-expanded="false">
                            <span class="dd-label">@selectedTenSanPham</span>
                        </button>

                        <div class="dropdown-menu w-100 p-2 shadow-sm dd-menu">
                            <input type="text"
                                   class="form-control form-control-sm mb-2 dd-search"
                                   placeholder="Gõ để tìm sản phẩm..."
                                   autocomplete="off" />

                            <div class="dd-list">
                                <button type="button"
                                        class="dropdown-item dd-item"
                                        data-value=""
                                        data-label="-- Tất cả --">
                                    -- Tất cả --
                                </button>

                                @if (sanPhamList != null)
                                {
                                    foreach (var sp in sanPhamList)
                                    {
                                        <button type="button"
                                                class="dropdown-item dd-item"
                                                data-value="@sp.MaSanPham"
                                                data-label="@sp.TenSanPham">
                                            @sp.TenSanPham
                                        </button>
                                    }
                                }
                            </div>
                        </div>

                        <input type="hidden"
                               name="maSanPham"
                               value="@selectedMaSanPham"
                               data-dd-hidden="maSanPham" />
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label small text-muted">Ảnh đại diện</label>

                    <div class="dropdown w-100 dd-wrap">
                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center"
                                type="button"
                                data-bs-toggle="dropdown"
                                data-dd="laAnhDaiDien"
                                aria-expanded="false">
                            <span class="dd-label">@laAnhLabel</span>
                        </button>

                        <div class="dropdown-menu w-100 p-2 shadow-sm dd-menu">
                            <input type="text"
                                   class="form-control form-control-sm mb-2 dd-search"
                                   placeholder="Gõ để lọc..."
                                   autocomplete="off" />

                            <div class="dd-list">
                                <button type="button"
                                        class="dropdown-item dd-item"
                                        data-value=""
                                        data-label="-- Tất cả --">
                                    -- Tất cả --
                                </button>
                                <button type="button"
                                        class="dropdown-item dd-item"
                                        data-value="true"
                                        data-label="Có">Có</button>
                                <button type="button"
                                        class="dropdown-item dd-item"
                                        data-value="false"
                                        data-label="Không">Không</button>
                            </div>
                        </div>

                        <input type="hidden"
                               name="laAnhDaiDien"
                               value="@(laAnhDaiDien?.ToString().ToLower() ?? "")"
                               data-dd-hidden="laAnhDaiDien" />
                    </div>
                </div>

                <div class="col-md-3 d-flex align-items-end justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary d-flex align-items-center gap-2 px-3">
                        <i class="fa-solid fa-filter"></i><span>Lọc</span>
                    </button>

                    <a asp-area="Admin" asp-controller="HinhAnhSanPham" asp-action="Index"
                       class="btn btn-outline-secondary d-flex align-items-center gap-2 px-3">
                        <i class="fa-solid fa-rotate-left"></i><span>Hủy</span>
                    </a>

                    <a asp-area="Admin" asp-controller="HinhAnhSanPham" asp-action="Create"
                       class="btn btn-success d-flex align-items-center gap-2 px-3">
                        <i class="fa-solid fa-plus"></i><span>Thêm</span>
                    </a>
                </div>
            </div>
        </form>

        <div class="px-4 py-2 text-muted small border-bottom">
            Tổng: <b>@(Model?.Count() ?? 0)</b> hình ảnh
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4" style="width:150px;">Mã ảnh</th>
                        <th>Sản phẩm</th>
                        <th class="text-center" style="width:140px;">Ảnh</th>
                        <th class="text-center" style="width:120px;">Đại diện</th>
                        <th class="text-center pe-4" style="width:140px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var img in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">@img.MaHinhAnh</td>
                                <td>
                                    <div class="fw-semibold">@img.MaSanPhamNavigation?.TenSanPham</div>
                                    <div class="text-muted small">Mã SP: @img.MaSanPham</div>
                                </td>
                                <td class="text-center">
                                    @if (!string.IsNullOrWhiteSpace(img.DuongDanAnh))
                                    {
                                        <img src="@img.DuongDanAnh" class="img-thumb" alt="Ảnh sản phẩm" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (img.LaAnhDaiDien == true)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">Có</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Không</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a class="btn btn-outline-secondary btn-sm"
                                           asp-area="Admin" asp-controller="HinhAnhSanPham" asp-action="Details" asp-route-id="@img.MaHinhAnh">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <a class="btn btn-outline-primary btn-sm"
                                           asp-area="Admin" asp-controller="HinhAnhSanPham" asp-action="Edit" asp-route-id="@img.MaHinhAnh">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a class="btn btn-outline-danger btn-sm"
                                           asp-area="Admin" asp-controller="HinhAnhSanPham" asp-action="Delete" asp-route-id="@img.MaHinhAnh">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">Không có hình ảnh nào</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/Admin/HinhAnh/Index.js" asp-append-version="true"></script>
}
