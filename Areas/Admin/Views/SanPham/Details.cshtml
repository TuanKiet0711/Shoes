@model WebBanGiay.Models.SanPham

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var tong = (Model.BienTheSanPham?.Sum(x => x.SoLuong ?? 0) ?? 0);
    var isHet = tong <= 0;
    var badgeClass = isHet ? "danger" : "success";
    var label = isHet ? "Hết hàng" : "Còn hàng";
}

<link rel="stylesheet" href="~/css/Admin/SanPham/Details.css" />
<div class="bt-page">
<div class="card border-0 shadow-sm bt-form bt-form--hero">
    <div class="card-header bt-hero">
        <div class="bt-hero-content">
            <div class="bt-hero-left">
                <span class="bt-icon">
                    <i class="fa-solid fa-eye"></i>
                </span>
                <div>
                    <div class="bt-title">Chi tiết sản phẩm</div>
                    <div class="bt-subtitle">Mã SP: @Model.MaSanPham</div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <a class="btn btn-light btn-sm bt-back"
                   asp-area="Admin" asp-controller="SanPham" asp-action="Index">
                    <i class="fa-solid fa-arrow-left"></i> Quay lại
                </a>
                <a class="btn btn-success btn-sm bt-primary"
                   asp-area="Admin" asp-controller="SanPham" asp-action="Edit" asp-route-id="@Model.MaSanPham">
                    <i class="fa-solid fa-pen"></i> Sửa
                </a>
            </div>
        </div>
    </div>

    <div class="card-body">
        <div class="bt-section">
            <div class="row g-3 bt-stack">
                <div class="col-12">
                    <div class="text-muted small">Tên sản phẩm</div>
                    <div class="fw-semibold">@Model.TenSanPham</div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">Danh mục</div>
                    <div class="fw-semibold">@(Model.MaDanhMucNavigation?.TenDanhMuc ?? "-")</div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">Thương hiệu</div>
                    <div class="fw-semibold">@(Model.MaThuongHieuNavigation?.TenThuongHieu ?? "-")</div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">Giới tính</div>
                    <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.GioiTinh) ? Model.GioiTinh : "-")</div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">Giá</div>
                    <div class="fw-semibold">@Model.Gia.ToString("N0") đ</div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">Tình trạng</div>
                    <span class="badge bg-@badgeClass px-3 py-2 rounded-pill">@label</span>
                </div>

                <div class="col-12">
                    <div class="text-muted small">Ngày tạo</div>
                    <div class="fw-semibold">
                        @(Model.NgayTao.HasValue ? Model.NgayTao.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                    </div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">Mô tả</div>
                    <div class="border rounded p-3 bg-light">
                        @(string.IsNullOrWhiteSpace(Model.MoTa) ? "Không có mô tả." : Model.MoTa)
                    </div>
                </div>
            </div>
        </div>

        <div class="bt-section mt-3">
            <div class="text-muted small mb-2">Biến thể</div>
            @if (Model.BienTheSanPham != null && Model.BienTheSanPham.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Biến thể</th>
                                <th class="text-end">SL</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bt in Model.BienTheSanPham)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">
                                            Size: @(bt.Size?.ToString() ?? "-")
                                            @if (!string.IsNullOrWhiteSpace(bt.MauSac))
                                            {
                                                <span class="ms-2 badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                                                    @bt.MauSac
                                                </span>
                                            }
                                        </div>
                                        <div class="text-muted small">Mã biến thể: @bt.MaBienThe</div>
                                    </td>
                                    <td class="text-end fw-semibold">@(bt.SoLuong ?? 0)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-muted">Chưa có biến thể.</div>
            }
        </div>

        <div class="bt-section mt-3">
            <div class="text-muted small mb-2">Hình ảnh</div>
            @if (Model.HinhAnhSanPham != null && Model.HinhAnhSanPham.Any())
            {
                <div class="row g-2">
                    @foreach (var img in Model.HinhAnhSanPham)
                    {
                        <div class="col-6 col-md-4 col-lg-2">
                            <div class="border rounded p-2 bg-white sp-thumb-wrap">
                                <img src="@img.DuongDanAnh" class="img-fluid rounded sp-thumb" alt="Ảnh sản phẩm" />
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-muted">Chưa có hình ảnh.</div>
            }
        </div>
    </div>
</div>
</div>
