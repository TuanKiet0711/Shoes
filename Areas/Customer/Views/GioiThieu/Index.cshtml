<!-- ================= CSS (GIỮ NGUYÊN + THÊM FADE SLIDE) ================= -->
<style>
    /* fade slide */
    .about-slide{
        position:absolute;
        inset:0;
        opacity:0;
        transition: opacity 900ms ease;
        pointer-events:none;
    }
    .about-slide.active{
        opacity:1;
        pointer-events:auto;
    }

    /* text animate lại khi đổi slide */
    .about-anim{ opacity:0; transform: translateY(14px); }
    .about-slide.active .about-anim{ animation: aboutFadeUp .8s ease forwards; }
    .about-slide.active .about-anim:nth-child(1){ animation-delay: .10s; }
    .about-slide.active .about-anim:nth-child(2){ animation-delay: .18s; }
    .about-slide.active .about-anim:nth-child(3){ animation-delay: .26s; }
    .about-slide.active .about-anim:nth-child(4){ animation-delay: .34s; }

    @@keyframes aboutFadeUp{
        from{ opacity:0; transform: translateY(18px); filter: blur(2px); }
        to{ opacity:1; transform: translateY(0); filter: blur(0); }
    }

    /* ===== giữ nguyên animation bạn có ===== */
    @@keyframes bannerZoom { from { transform: scale(1.08); } to { transform: scale(1.24); } }
    .animate-bannerZoom { animation: bannerZoom 22s ease-in-out infinite alternate; }

    @@keyframes lightMove { from { transform: translateX(-120%); } to { transform: translateX(120%); } }
    .animate-lightMove { animation: lightMove 10s linear infinite; }

    @@keyframes parallaxMove {
        0% { transform: translate3d(-1.5%, -1%, 0) scale(1.06); }
        50% { transform: translate3d(1.5%, 1%, 0) scale(1.07); }
        100% { transform: translate3d(-1.5%, -1%, 0) scale(1.06); }
    }
    .animate-parallaxMove { animation: parallaxMove 14s ease-in-out infinite; }

    .bokeh{
        position:absolute;
        width: 180px; height: 180px;
        border-radius:999px;
        background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.22), rgba(255,255,255,0) 60%);
        filter: blur(1px);
        opacity: .55;
        animation: bokehFloat 9s ease-in-out infinite;
        mix-blend-mode: screen;
    }
    @@keyframes bokehFloat{
        0%,100%{ transform: translateY(0) translateX(0) scale(1); opacity:.45; }
        50%{ transform: translateY(-22px) translateX(12px) scale(1.06); opacity:.7; }
    }
    .b1{ top: 12%; left: 8%;  animation-duration: 10s; }
    .b2{ top: 18%; right: 12%; width: 140px; height: 140px; animation-duration: 12s; }
    .b3{ bottom: 8%; left: 18%; width: 220px; height: 220px; animation-duration: 13s; opacity:.4; }
    .b4{ bottom: 18%; right: 22%; width: 160px; height: 160px; animation-duration: 11s; }
    .b5{ top: 42%; left: 44%; width: 120px; height: 120px; animation-duration: 9s; opacity:.35; }

    @@media (prefers-reduced-motion: reduce){
        .animate-bannerZoom, .animate-lightMove, .animate-parallaxMove { animation: none !important; }
        .bokeh { display:none; }
        .about-anim { animation:none !important; opacity:1 !important; transform:none !important; filter:none !important; }
    }
</style>


<!-- ================= CÂU CHUYỆN LEESHOES + VIDEO ================= -->
<section id="story" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

            <!-- VIDEO -->
            <div class="relative rounded-3xl overflow-hidden shadow-xl">
                <video class="w-full h-[280px] md:h-[340px] object-cover"
                       autoplay muted loop playsinline preload="metadata"
                       poster="https://images.unsplash.com/photo-1519744792095-2f2205e87b6f">
                    <source src="~/videos/leeshoes-intro.mp4" type="video/mp4" />
                    Trình duyệt của bạn không hỗ trợ video.
                </video>
                <div class="absolute inset-0 bg-black/10 pointer-events-none"></div>
            </div>

            <!-- CONTENT -->
            <div>
                <h2 class="text-4xl font-extrabold uppercase mb-8">Câu chuyện LeeShoes</h2>

                <p class="text-gray-600 mb-6 leading-relaxed text-lg">
                    Từ những ngày đầu chỉ là một cửa hàng nhỏ, LeeShoes được xây dựng
                    bởi những con người yêu giày, am hiểu sneaker và trân trọng từng
                    trải nghiệm của khách hàng. Mỗi đôi giày được chọn lọc kỹ lưỡng,
                    không chỉ dựa trên thương hiệu, mà còn dựa trên chất lượng,
                    độ bền và cảm giác khi mang trên chân.
                </p>

                <p class="text-gray-600 mb-6 leading-relaxed text-lg">
                    Chúng tôi hiểu rằng, một đôi giày tốt không chỉ giúp bạn tự tin hơn,
                    mà còn đồng hành cùng bạn trong công việc, những chuyến đi,
                    những khoảnh khắc đáng nhớ của cuộc sống.
                    Vì thế, LeeShoes luôn đặt sự chỉn chu và uy tín lên hàng đầu
                    trong từng sản phẩm.
                </p>

                <p class="text-gray-600 leading-relaxed text-lg">
                    Hành trình của LeeShoes không dừng lại ở việc bán giày.
                    Chúng tôi mong muốn xây dựng một cộng đồng yêu phong cách,
                    nơi mỗi bước chân đều mang theo cá tính,
                    đam mê và câu chuyện riêng của bạn.
                </p>
            </div>

        </div>
    </div>
</section>

