@model WebBanGiay.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}
<link rel="stylesheet" href="~/css/Customer/AuthModal.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Customer/ForgotPassword.css" asp-append-version="true" />

<section class="auth-overlay is-open">
    <div class="auth-backdrop"></div>
    <div class="auth-modal auth-modal--single" role="dialog" aria-modal="true" aria-label="Đặt lại mật khẩu">
        <a class="auth-close" href="/" aria-label="Đóng">
            <i class="fa-solid fa-xmark"></i>
        </a>

        <div class="auth-split auth-split--single">
            <section class="auth-panel auth-panel--login auth-panel--center">
                <h2 class="auth-title">Đặt lại mật khẩu</h2>
                <p class="auth-subtitle">Tạo mật khẩu mới cho tài khoản của bạn.</p>

                <form class="auth-form auth-form--reset" method="post" asp-action="ResetPassword" asp-controller="ForgotPassword" asp-area="Customer">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Email" value="@Model.Email" />
                    <input type="hidden" name="Token" value="@Model.Token" />

                    <div class="auth-field">
                        <label for="AuthResetPassword">Mật khẩu mới</label>
                        <div class="auth-input-wrap">
                            <input id="AuthResetPassword" name="MatKhauMoi" type="password" placeholder="Tối thiểu 6 ký tự" minlength="6" required />
                            <button type="button" class="auth-toggle" data-toggle-password="#AuthResetPassword" aria-label="Hiển thị mật khẩu">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        <span class="field-error">@Html.ValidationMessageFor(m => m.MatKhauMoi)</span>
                    </div>

                    <div class="auth-field">
                        <label for="AuthResetConfirm">Xác nhận mật khẩu</label>
                        <div class="auth-input-wrap">
                            <input id="AuthResetConfirm" name="XacNhanMatKhau" type="password" placeholder="Nhập lại mật khẩu" minlength="6" required />
                            <button type="button" class="auth-toggle" data-toggle-password="#AuthResetConfirm" aria-label="Hiển thị mật khẩu">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        <span class="field-error">@Html.ValidationMessageFor(m => m.XacNhanMatKhau)</span>
                    </div>

                    <div class="auth-error">@Html.ValidationSummary(true)</div>

                    <button type="submit" class="auth-btn">Đổi mật khẩu</button>
                </form>

                <div class="auth-switch">
                    <a href="/Customer/Login">Quay lại đăng nhập</a>
                </div>
            </section>
        </div>
    </div>
</section>

@section Scripts{
    <script src="~/js/Customer/ResetPassword.js" asp-append-version="true"></script>
}
