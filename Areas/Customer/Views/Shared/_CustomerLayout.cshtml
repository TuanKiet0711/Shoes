<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>

<body class="bg-gray-50 text-gray-800">

<!-- ================= HEADER ================= -->
<header class="bg-white border-b sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex items-center justify-between h-20">

            <!-- LOGO -->
            <a href="/" class="text-3xl font-extrabold tracking-tight">
                LEE<span class="text-indigo-600">SHOES</span>
            </a>

            <!-- MENU -->
            <nav class="hidden lg:flex items-center gap-8 font-medium">

                <a href="/" class="hover:text-indigo-600 transition">Trang chủ</a>
                <a href="#" class="hover:text-indigo-600 transition">Tất cả</a>

                <!-- DANH MỤC -->
                <div class="relative group">
                    <button class="flex items-center gap-1 hover:text-indigo-600 transition">
                        Danh mục <i class="fa-solid fa-chevron-down text-xs"></i>
                    </button>
                    <div class="absolute left-1/2 -translate-x-1/2 top-full mt-4 w-56 bg-white rounded-xl shadow-xl border opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-[9999]">
                        @if (ViewBag.DanhMuc != null) {
                            foreach (var dm in ViewBag.DanhMuc) {
                                <a href="#" class="block px-5 py-3 hover:bg-indigo-50 hover:text-indigo-600 transition">
                                    @dm.TenDanhMuc
                                </a>
                            }
                        }
                    </div>
                </div>
                <!-- THƯƠNG HIỆU -->
                <div class="relative group">
                    <button class="flex items-center gap-1 hover:text-indigo-600 transition">
                        Thương hiệu <i class="fa-solid fa-chevron-down text-xs"></i>
                    </button>

                    <div class="absolute left-1/2 -translate-x-1/2 top-full mt-4 w-56
                                bg-white rounded-xl shadow-xl border
                                opacity-0 invisible
                                group-hover:opacity-100 group-hover:visible
                                transition-all duration-200
                                z-[9999]">
                        @if (ViewBag.ThuongHieu != null)
{
    foreach (var th in ViewBag.ThuongHieu)
    {
        <a href="#"
           class="block px-5 py-3 hover:bg-indigo-50 hover:text-indigo-600 transition">
            @th.TenThuongHieu
        </a>
    }
}

                    </div>
                </div>

                <a href="#" class="hover:text-indigo-600 transition">Nam</a>
                <a href="#" class="hover:text-indigo-600 transition">Nữ</a>
                <a href="/Customer/GioiThieu" class="hover:text-indigo-600 transition">
    Về LeeShoes
</a>

            </nav>

            <!-- ACTION -->
            <div class="flex items-center gap-5">

                <!-- SEARCH -->
                <form asp-area="Customer"
      asp-controller="SanPham"
      asp-action="TimKiem"
      method="get"
      class="hidden md:flex items-center bg-gray-100 rounded-full px-4 py-2
             focus-within:ring-2 focus-within:ring-indigo-500 transition">

    <!-- ICON = BUTTON SUBMIT -->
    <button type="submit"
            class="text-gray-400 hover:text-indigo-600 transition">
        <i class="fa-solid fa-magnifying-glass"></i>
    </button>

    <input type="text"
           name="q"
           placeholder="Tìm giày, thương hiệu..."
           class="bg-transparent outline-none px-3 w-56 text-sm" />
</form>


                <!-- USER -->
               <div class="relative group">
    <button class="hover:text-indigo-600 transition">
        <i class="fa-regular fa-user text-xl"></i>
    </button>

    <div class="
        absolute top-full mt-4
        left-1/2 -translate-x-1/2
        w-52
        bg-white rounded-xl shadow-xl border
        opacity-0 invisible
        group-hover:opacity-100 group-hover:visible
        transition-all duration-200
        z-[9999]
    ">
        <a class="block px-5 py-3 hover:bg-indigo-50 hover:text-indigo-600 transition text-sm">
            <i class="fa-solid fa-right-to-bracket mr-2"></i> Đăng nhập
        </a>

        <a class="block px-5 py-3 hover:bg-indigo-50 hover:text-indigo-600 transition text-sm">
            <i class="fa-solid fa-user-plus mr-2"></i> Đăng ký
        </a>
    </div>
</div>

                <!-- CART -->
                <a href="#" class="relative hover:text-indigo-600 transition">
                    <i class="fa-solid fa-bag-shopping text-xl"></i>
                   
                </a>

            </div>
        </div>
    </div>
</header>

<!-- ================= CONTENT ================= -->
<main class="min-h-screen max-w-7xl mx-auto px-6 py-10">
    @RenderBody()
    @RenderSection("Scripts", required: false)

</main>

<!-- ================= FOOTER ================= -->
<footer class="bg-white border-t">
    <div class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-4 gap-12">

        <!-- BRAND -->
        <div>
            <h3 class="text-2xl font-bold mb-4">
                LEE<span class="text-indigo-600">SHOES</span>
            </h3>
            <p class="text-gray-500 leading-relaxed text-sm">
                Leeshos là thương hiệu giày thể thao cao cấp, mang đến phong cách hiện đại,
                chất lượng bền bỉ và sự tự tin trong từng bước chân.
            </p>

            <!-- SOCIAL -->
            <div class="flex gap-4 mt-6">
                <a class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-100
                          hover:bg-indigo-600 hover:text-white transition">
                    <i class="fa-brands fa-facebook-f"></i>
                </a>
                <a class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-100
                          hover:bg-indigo-600 hover:text-white transition">
                    <i class="fa-brands fa-instagram"></i>
                </a>
                <a class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-100
                          hover:bg-indigo-600 hover:text-white transition">
                    <i class="fa-brands fa-tiktok"></i>
                </a>
            </div>
        </div>

        <!-- SHOP -->
        <div>
            <h4 class="font-semibold mb-4">Mua sắm</h4>
            <ul class="space-y-3 text-gray-500 text-sm">
                <li><a class="hover:text-indigo-600 transition">Tất cả sản phẩm</a></li>
                <li><a class="hover:text-indigo-600 transition">Giày Nam</a></li>
                <li><a class="hover:text-indigo-600 transition">Giày Nữ</a></li>
                <li><a class="hover:text-indigo-600 transition">Bộ sưu tập mới</a></li>
            </ul>
        </div>

        <!-- SUPPORT -->
        <div>
            <h4 class="font-semibold mb-4">Hỗ trợ khách hàng</h4>
            <ul class="space-y-3 text-gray-500 text-sm">
                <li><a class="hover:text-indigo-600 transition">Chính sách đổi trả</a></li>
                <li><a class="hover:text-indigo-600 transition">Chính sách bảo hành</a></li>
                <li><a class="hover:text-indigo-600 transition">Theo dõi đơn hàng</a></li>
                <li><a class="hover:text-indigo-600 transition">Liên hệ hỗ trợ</a></li>
            </ul>
        </div>

        <!-- NEWSLETTER -->
        <div>
            <h4 class="font-semibold mb-4">Nhận ưu đãi</h4>
            <p class="text-sm text-gray-500 mb-4">
                Nhận mã giảm giá <span class="font-semibold text-indigo-600">10%</span>
                cho đơn hàng đầu tiên.
            </p>
            <div class="relative">
                <input type="email"
                       placeholder="Email của bạn"
                       class="w-full rounded-full bg-gray-100 px-5 py-3 text-sm
                              focus:ring-2 focus:ring-indigo-500 outline-none">
                <button class="absolute right-1 top-1 bg-indigo-600 text-white
                               px-5 py-2 rounded-full text-sm hover:bg-indigo-700 transition">
                    Đăng ký
                </button>
            </div>

            <!-- CONTACT -->
            <div class="mt-6 text-sm text-gray-500 space-y-2">
                <p><i class="fa-solid fa-phone mr-2"></i> 0707 667 306</p>
                <p><i class="fa-solid fa-envelope mr-2"></i> support@leeshos.vn</p>
                <p class="flex items-start">
        <i class="fa-solid fa-location-dot mr-2 mt-0.5"></i>
        <span>
            1122 Quang Trung, phường 8<br>
            Quận Gò Vấp, TP. Hồ Chí Minh
        </span>
    </p>
            </div>
            
        </div>
    </div>

    <!-- BOTTOM -->
    <div class="border-t py-6">
    <div class="max-w-7xl mx-auto px-6 text-center text-xs text-gray-400">
        © 2024 Leeshos. All rights reserved.
    </div>
</div>

</footer>

</body>
</html>
