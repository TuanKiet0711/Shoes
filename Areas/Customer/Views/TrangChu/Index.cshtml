@model List<WebBanGiay.Models.SanPham>

@{
    ViewData["Title"] = "Trang chủ - ";
}

<!-- ================= BANNER SLIDER CSS ================= -->
<style>
    .slide {
        opacity: 0;
        position: absolute;
        inset: 0;
        transition: opacity 1s ease;
    }
    .slide.active {
        opacity: 1;
        z-index: 10;
    }
    .slide img {
        animation: zoomSoft 8s ease-in-out infinite alternate;
    }
    @@keyframes zoomSoft {
        from { transform: scale(1); }
        to { transform: scale(1.1); }
    }
    .fade-slide {
        animation: fadeSlideUp 1s ease forwards;
        opacity: 0;
    }
    @@keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .delay-1 { animation-delay: .2s; }
    .delay-2 { animation-delay: .4s; }
    .delay-3 { animation-delay: .6s; }
</style>

<!-- ================= BANNER SLIDER ================= -->
<section class="relative h-[520px] rounded-3xl overflow-hidden mb-20">
    <div class="relative w-full h-full">

        <!-- SLIDE 1 -->
        <div class="slide active">
            <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 to-indigo-700/50"></div>
            <div class="absolute inset-0 flex items-center px-12 text-white">
                <div class="max-w-3xl">
                    <span class="bg-indigo-600 px-4 py-2 rounded-full text-xs fade-slide delay-1">Bộ sưu tập mới</span>
                    <h1 class="text-5xl font-extrabold my-6 fade-slide delay-2">
                        Phong cách <span class="text-indigo-300">thể thao</span>
                    </h1>
                    <p class="mb-8 text-gray-200 fade-slide delay-3">Giày chính hãng – Thiết kế hiện đại – Giá tốt</p>
                    <a class="bg-indigo-600 px-8 py-4 rounded-full font-semibold">Mua ngay</a>
                </div>
            </div>
        </div>

        <!-- SLIDE 2 -->
        <div class="slide">
            <img src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 to-pink-600/50"></div>
            <div class="absolute inset-0 flex items-center px-12 text-white">
                <div class="max-w-3xl">
                    <span class="bg-pink-600 px-4 py-2 rounded-full text-xs fade-slide delay-1">New Arrival</span>
                    <h1 class="text-5xl font-extrabold my-6 fade-slide delay-2">
                        Nâng tầm <span class="text-pink-300">phong cách</span>
                    </h1>
                    <p class="mb-8 text-gray-200 fade-slide delay-3">Sẵn sàng cho mọi bước đi</p>
                    <a class="bg-pink-600 px-8 py-4 rounded-full font-semibold">Mua ngay</a>
                </div>
            </div>
        </div>

        <!-- SLIDE 3 -->
        <div class="slide">
            <img src="https://images.unsplash.com/photo-1519744792095-2f2205e87b6f" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 to-green-600/50"></div>
            <div class="absolute inset-0 flex items-center px-12 text-white">
                <div class="max-w-3xl">
                    <span class="bg-green-600 px-4 py-2 rounded-full text-xs fade-slide delay-1">Thành công</span>
                    <h1 class="text-5xl font-extrabold my-6 fade-slide delay-2">
                        Bước đi <span class="text-green-300">tự tin</span>
                    </h1>
                    <p class="mb-8 text-gray-200 fade-slide delay-3">Đường dẫn đến phong cách hoàn hảo</p>
                    <a class="bg-green-600 px-8 py-4 rounded-full font-semibold">Mua ngay</a>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    const slides = document.querySelectorAll('.slide');
    let current = 0;
    setInterval(() => {
        slides[current].classList.remove('active');
        current = (current + 1) % slides.length;
        slides[current].classList.add('active');
    }, 3000);
</script>

<!-- ================= SẢN PHẨM ================= -->
<section class="mb-24">
    <div class="max-w-7xl mx-auto px-6">

        <h2 class="text-4xl font-extrabold uppercase mb-16 text-center">
            Sản phẩm nổi bật
        </h2>

        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                @foreach (var sp in Model)
                {
                    var hinh = (sp.HinhAnhSanPham != null && sp.HinhAnhSanPham.Any())
                        ? sp.HinhAnhSanPham.First().DuongDanAnh
                        : "https://via.placeholder.com/400";

                    <div class="bg-white rounded-2xl shadow hover:shadow-xl overflow-hidden">
                        <img src="@hinh"
                             class="h-56 w-full object-cover" />

                        <div class="p-5">
                            <h3 class="font-semibold text-lg">
                                @sp.TenSanPham
                            </h3>

                            <p class="text-sm text-gray-500">
                                @sp.MaThuongHieuNavigation?.TenThuongHieu
                            </p>

                            <div class="flex justify-between items-center mt-3">
                                <span class="text-indigo-600 font-bold">
                                    @sp.Gia.ToString("N0") đ
                                </span>
                                <i class="fa-solid fa-cart-plus text-indigo-600"></i>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-center text-gray-500">
                ❌ Không có sản phẩm nào để hiển thị
            </p>
        }

    </div>
</section>

