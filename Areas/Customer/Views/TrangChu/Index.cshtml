@model List<WebBanGiay.Models.SanPham>

@{
    ViewData["Title"] = "Trang chủ ";
}
<link rel="stylesheet" href="~/css/Customer/TrangChu.css" asp-append-version="true" />
<!-- ================= BANNER SLIDER CSS ================= -->

<!-- ================= BANNER SLIDER (thụt 1cm mỗi bên + bo góc) ================= -->
<section class="relative h-[520px] overflow-hidden mb-20 w-full">
    <div class="relative w-full h-full rounded-3xl md:rounded-[2rem] overflow-hidden">
        <!-- SLIDE 1 -->
   <!-- SLIDE 1 (NHIỀU MÃ GIẢM GIÁ) -->
<div class="slide active">
    <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff"
         class="w-full h-full object-cover"
         loading="eager"
         decoding="async"
         fetchpriority="high" />

    <div class="absolute inset-0 bg-gradient-to-r from-black/85 to-rose-700/50"></div>

    <div class="absolute inset-0 flex items-center px-12 text-white">
        <div class="max-w-3xl">

            <!-- BADGE -->
            <span class="bg-rose-600 px-4 py-2 rounded-full text-xs font-bold fade-slide delay-1">
                🎉 ƯU ĐÃI ĐẶC BIỆT
            </span>

            <!-- TITLE -->
            <h1 class="text-5xl font-extrabold my-6 fade-slide delay-2">
                Nhiều mã giảm giá <br />
                <span class="text-rose-300">lên đến 30%</span>
            </h1>

            <!-- DESC -->
            <p class="mb-8 text-gray-200 fade-slide delay-3">
                Áp dụng cho nhiều sản phẩm chính hãng.<br />
                Số lượng mã có hạn – nhanh tay kẻo lỡ!
            </p>

            <!-- LIST MÃ (visual) -->
           

            <!-- CTA -->
            <a href="/Customer/TrangChu"
               class="inline-flex items-center gap-3 bg-rose-600 hover:bg-rose-700
                      px-10 py-5 rounded-full font-extrabold text-lg transition">
                <i class="fa-solid fa-bag-shopping"></i>
                Mua ngay
            </a>

        </div>
    </div>
</div>

        <!-- SLIDE 2 -->
        <div class="slide">
            <img src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519"
                 class="w-full h-full object-cover"
                 loading="lazy"
                 decoding="async" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 to-pink-600/50"></div>
            <div class="absolute inset-0 flex items-center px-12 text-white">
                <div class="max-w-3xl">
                    <span class="bg-pink-600 px-4 py-2 rounded-full text-xs fade-slide delay-1">New Arrival</span>
                    <h1 class="text-5xl font-extrabold my-6 fade-slide delay-2">
                        Nâng tầm <span class="text-pink-300">phong cách</span>
                    </h1>
                    <p class="mb-8 text-gray-200 fade-slide delay-3">Sẵn sàng cho mọi bước đi</p>
                    <a href="/Customer/TrangChu" class="bg-pink-600 px-8 py-4 rounded-full font-semibold">Mua ngay</a>
                </div>
            </div>
        </div>

        <!-- SLIDE 3 -->
        <div class="slide">
            <img src="https://images.unsplash.com/photo-1519744792095-2f2205e87b6f"
                 class="w-full h-full object-cover"
                 loading="lazy"
                 decoding="async" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 to-green-600/50"></div>
            <div class="absolute inset-0 flex items-center px-12 text-white">
                <div class="max-w-3xl">
                    <span class="bg-green-600 px-4 py-2 rounded-full text-xs fade-slide delay-1">Thành công</span>
                    <h1 class="text-5xl font-extrabold my-6 fade-slide delay-2">
                        Bước đi <span class="text-green-300">tự tin</span>
                    </h1>
                    <p class="mb-8 text-gray-200 fade-slide delay-3">Đường dẫn đến phong cách hoàn hảo</p>
                    <a href="/Customer/TrangChu" class="bg-green-600 px-8 py-4 rounded-full font-semibold">Mua ngay</a>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ================= SẢN PHẨM ================= -->
<section class="mb-24">
    <div class="max-w-7xl mx-auto px-6">

        <h2 class="text-4xl font-extrabold uppercase mb-16 text-center">
            Sản phẩm nổi bật
        </h2>

        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                @foreach (var sp in Model)
                {
                    var imageUrls = (sp.HinhAnhSanPham ?? new List<WebBanGiay.Models.HinhAnhSanPham>())
                        .Where(x => !string.IsNullOrWhiteSpace(x.DuongDanAnh))
                        .OrderByDescending(x => x.LaAnhDaiDien == true)
                        .Select(x => x.DuongDanAnh)
                        .ToList();
                    var hinh = imageUrls.Any() ? imageUrls.First() : "https://via.placeholder.com/400";
                    var hinhAlt = imageUrls.Count > 1 ? imageUrls[1] : "";

                    <div class="bg-white rounded-2xl shadow hover:shadow-xl overflow-hidden tc-tilt">
                        <div class="h-56 w-full tc-swap">
                            <img src="@hinh"
                                 class="tc-tilt-img tc-swap-img"
                                 loading="lazy"
                                 decoding="async" />
                            @if (!string.IsNullOrWhiteSpace(hinhAlt))
                            {
                                <img src="@hinhAlt"
                                     class="tc-tilt-img tc-swap-img tc-swap-img--alt"
                                     loading="lazy"
                                     decoding="async" />
                            }
                        </div>

                        <div class="p-5 tc-tilt-body">
                            <h3 class="font-semibold text-lg">
                                @sp.TenSanPham
                            </h3>

                            <p class="text-sm text-gray-500">
                                @sp.MaThuongHieuNavigation?.TenThuongHieu
                            </p>

                            <div class="flex justify-between items-center mt-3">
                                <span class="text-indigo-600 font-bold">
                                    @sp.Gia.ToString("N0") đ
                                </span>
                                <i class="fa-solid fa-cart-plus text-indigo-600"></i>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-center text-gray-500">
                ❌ Không có sản phẩm nào để hiển thị
            </p>
        }

    </div>
</section>

@{
    var thuongHieus = ViewBag.ThuongHieu as List<WebBanGiay.Models.ThuongHieu>;

    // map ảnh cho từng thương hiệu
    var brandImages = new Dictionary<string, string>
    {
        { "Nike", "https://i.pinimg.com/736x/03/b3/c2/03b3c26598ec04ae8772395a7601a214.jpg" },
        { "Adidas", "https://i.pinimg.com/736x/c3/66/53/c36653b7aef19e5a4a78f7d173efbdf8.jpg" },
        { "New Balance", "https://thumbs.dreamstime.com/b/new-balance-logo-sign-footwear-shop-black-friday-sale-market-201830065.jpg" },
        { "Puma", "https://nguoinoitieng.tv/images/nnt/107/0/bjvk.jpg" },
        { "Vans", "https://drake.vn/image/catalog/H%C3%ACnh%20content/hinh-anh-giay-vans/hinh-anh-giay-vans-23.jpg" },
        { "Biti’s", "https://event.mediacdn.vn/thumb_w/1000/257767050295742464/image/cca/2023/10/5/bitis-16964818738691141360063.jpg" }
    };
}

<!-- ================= THƯƠNG HIỆU NỔI BẬT ================= -->
<section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">

        <h2 class="text-4xl font-extrabold uppercase mb-16 text-center">
            Thương hiệu nổi bật
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
            @foreach (var th in thuongHieus)
            {
                var img = brandImages.ContainsKey(th.TenThuongHieu)
                    ? brandImages[th.TenThuongHieu]
                    : "https://via.placeholder.com/600x800";

                <a href="@Url.Action("Index", "TrangChu", new { brand = th.TenThuongHieu })"
                   class="group relative overflow-hidden rounded-3xl shadow-lg tc-tilt">

                    <img src="@img"
                         class="w-full h-[520px] object-cover transition duration-700 group-hover:scale-110 tc-tilt-img"
                         loading="lazy"
                         decoding="async" />

                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>

                    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 tc-tilt-body
                                bg-white/90 backdrop-blur px-10 py-4 rounded-full
                                font-extrabold text-xl tracking-wide">
                        @th.TenThuongHieu
                    </div>
                </a>
            }
        </div>
    </div>
</section>

<!-- ================= FAQ + SERVICE (2 CỘT) ================= -->
<section class="bg-white py-24 border-t">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-20">

        <!-- FAQ -->
        <div>
            <h2 class="text-4xl font-extrabold mb-12 uppercase">
                Câu hỏi<br />thường gặp
            </h2>

            <div class="space-y-6">
                @foreach (var item in new[]
                {
                    new { Q="Lợi ích khi trở thành thành viên là gì?", A="Tích điểm mỗi đơn hàng, nhận ưu đãi độc quyền và thông báo sớm sản phẩm mới."},
                    new { Q="Làm thế nào để mua sắm?", A="Bạn có thể mua trực tiếp tại cửa hàng hoặc đặt hàng online nhanh chóng."},
                    new { Q="Xem kích thước sản phẩm thế nào?", A="Bảng size chi tiết được hiển thị trong trang sản phẩm."},
                    new { Q="Hình thức thanh toán?", A="Thanh toán khi nhận hàng (COD), Stripe."},
                    new { Q="Phí vận chuyển bao nhiêu?", A="Miễn phí vận chuyển cho đơn hàng từ 2.000.000đ."}
                })
                {
                    <div class="bg-gray-50 rounded-2xl p-6">
                        <button class="faq-question w-full flex justify-between items-center font-semibold text-lg">
                            @item.Q
                            <span class="text-2xl text-indigo-600">+</span>
                        </button>
                        <div class="faq-answer max-h-0 overflow-hidden transition-all duration-500 mt-4 text-gray-600 leading-relaxed">
                            @item.A
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- SERVICE / CAM KẾT -->
        <div>
            <h2 class="text-4xl font-extrabold mb-12 uppercase">
                Dịch vụ<br />& cam kết
            </h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">

                <div class="p-8 rounded-3xl bg-gray-50 hover:shadow-xl transition">
                    <i class="fa-solid fa-truck-fast text-4xl text-indigo-600 mb-5"></i>
                    <h3 class="font-bold text-xl mb-3">Giao hàng nhanh</h3>
                    <p class="text-gray-600">Nhận hàng chỉ từ 1–3 ngày trên toàn quốc</p>
                </div>

                <div class="p-8 rounded-3xl bg-gray-50 hover:shadow-xl transition">
                    <i class="fa-solid fa-shield-halved text-4xl text-green-600 mb-5"></i>
                    <h3 class="font-bold text-xl mb-3">Chính hãng 100%</h3>
                    <p class="text-gray-600">Cam kết hàng chính hãng, hoàn tiền nếu phát hiện giả</p>
                </div>

                <div class="p-8 rounded-3xl bg-gray-50 hover:shadow-xl transition">
                    <i class="fa-solid fa-arrows-rotate text-4xl text-pink-600 mb-5"></i>
                    <h3 class="font-bold text-xl mb-3">Đổi trả dễ dàng</h3>
                    <p class="text-gray-600">Hỗ trợ đổi size, đổi mẫu trong 7 ngày</p>
                </div>

                <div class="p-8 rounded-3xl bg-gray-50 hover:shadow-xl transition">
                    <i class="fa-solid fa-headset text-4xl text-orange-500 mb-5"></i>
                    <h3 class="font-bold text-xl mb-3">Hỗ trợ 24/7</h3>
                    <p class="text-gray-600">Đội ngũ tư vấn luôn sẵn sàng hỗ trợ bạn</p>
                </div>

            </div>
        </div>

    </div>
</section>

@section Scripts{
    <script src="~/js/Customer/TrangChu.js" asp-append-version="true"></script>
    
}
