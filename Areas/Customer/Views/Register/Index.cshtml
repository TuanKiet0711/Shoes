@model WebBanGiay.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}
<link rel="stylesheet" href="~/css/Customer/AuthModal.css" asp-append-version="true" />

<section class="auth-overlay is-open">
    <div class="auth-backdrop"></div>
    <div class="auth-modal" role="dialog" aria-modal="true" aria-label="Đăng nhập và đăng ký">
        <a class="auth-close" href="/" aria-label="Đóng">
            <i class="fa-solid fa-xmark"></i>
        </a>

        <div class="auth-split">
            <section class="auth-panel auth-panel--login">
                <h2 class="auth-title">Đăng nhập</h2>
                <p class="auth-subtitle">Nhập thông tin để tiếp tục mua sắm cùng LeeShoes.</p>

                <form class="auth-form auth-form--login" method="post" asp-action="Index" asp-controller="Login" asp-area="Customer">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ReturnUrl" value="@returnUrl" />

                    <div class="auth-field">
                        <label for="AuthLoginEmail">Email</label>
                        <input id="AuthLoginEmail" name="Email" type="email" placeholder="Nhập email" required />
                    </div>

                    <div class="auth-field">
                        <label for="AuthLoginPassword">Mật khẩu</label>
                        <div class="auth-input-wrap">
                            <input id="AuthLoginPassword" name="MatKhau" type="password" placeholder="Nhập mật khẩu" minlength="6" required />
                            <button type="button" class="auth-toggle" data-toggle-password="#AuthLoginPassword" aria-label="Hiển thị mật khẩu">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="auth-btn">Đăng nhập</button>
                </form>
            </section>

            <section class="auth-panel auth-panel--register">
                <h2 class="auth-title">Đăng ký</h2>
                <p class="auth-subtitle">Tạo tài khoản để nhận ưu đãi và theo dõi đơn hàng dễ dàng.</p>

                <form class="auth-form auth-form--register" method="post" asp-action="Index" asp-controller="Register" asp-area="Customer">
                    @Html.AntiForgeryToken()

                    <div class="auth-field">
                        <label for="AuthRegisterHoTen">Họ và tên</label>
                        <input id="AuthRegisterHoTen" name="HoTen" type="text" value="@Model.HoTen" placeholder="Nhập họ tên" required />
                        <span class="field-error">@Html.ValidationMessageFor(m => m.HoTen)</span>
                    </div>

                    <div class="auth-row">
                        <div class="auth-field">
                            <label for="AuthRegisterGioiTinh">Giới tính</label>
                            <select id="AuthRegisterGioiTinh" name="GioiTinh" required>
                                <option value="">Chọn giới tính</option>
                                <option value="Nam" selected="@(Model.GioiTinh == "Nam")">Nam</option>
                                <option value="Nu" selected="@(Model.GioiTinh == "Nu")">Nữ</option>
                                <option value="Khac" selected="@(Model.GioiTinh == "Khac")">Khác</option>
                            </select>
                            <span class="field-error">@Html.ValidationMessageFor(m => m.GioiTinh)</span>
                        </div>

                        <div class="auth-field">
                            <label for="AuthRegisterNgaySinh">Ngày sinh</label>
                            <div class="auth-date">
                                <input id="AuthRegisterNgaySinh" name="NgaySinh" type="text" inputmode="numeric" class="auth-date-input"
                                       placeholder="dd/MM/yyyy" value="@Model.NgaySinh" maxlength="10" autocomplete="bday" required />
                                <button type="button" class="auth-date-btn" data-date-picker aria-label="Chọn ngày sinh">
                                    <i class="fa-regular fa-calendar"></i>
                                </button>
                            </div>
                            <input id="NgaySinhPicker" type="date" class="auth-date-picker" tabindex="-1" />
                            <span class="field-error" data-error-for="NgaySinh">@Html.ValidationMessageFor(m => m.NgaySinh)</span>
                        </div>
                    </div>

                    <div class="auth-row">
                        <div class="auth-field">
                            <label for="AuthRegisterEmail">Email</label>
                            <input id="AuthRegisterEmail" name="Email" type="email" value="@Model.Email" placeholder="Nhập email" required />
                            <span class="field-error">@Html.ValidationMessageFor(m => m.Email)</span>
                        </div>

                        <div class="auth-field">
                            <label for="AuthRegisterSdt">Số điện thoại</label>
                            <input id="AuthRegisterSdt" name="Sdt" type="tel" value="@Model.Sdt" placeholder="Nhập số điện thoại" inputmode="numeric" pattern="\d{10}" minlength="10" maxlength="10" required />
                            <span class="field-error" data-error-for="Sdt"></span>
                            <span class="field-error">@Html.ValidationMessageFor(m => m.Sdt)</span>
                        </div>
                    </div>

                    <div class="auth-field">
                        <label for="AuthRegisterMatKhau">Mật khẩu</label>
                        <div class="auth-input-wrap">
                            <input id="AuthRegisterMatKhau" name="MatKhau" type="password" placeholder="Tối thiểu 6 ký tự" minlength="6" required />
                            <button type="button" class="auth-toggle" data-toggle-password="#AuthRegisterMatKhau" aria-label="Hiển thị mật khẩu">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        <span class="field-error">@Html.ValidationMessageFor(m => m.MatKhau)</span>
                        <div class="auth-strength" data-strength>
                            <div class="auth-strength-bar" data-strength-bar></div>
                            <span class="auth-strength-text" data-strength-text>Độ mạnh</span>
                        </div>
                        <span class="field-error" data-error-for="MatKhau"></span>
                    </div>

                    <div class="auth-field">
                        <label for="AuthRegisterXacNhan">Xác nhận mật khẩu</label>
                        <div class="auth-input-wrap">
                            <input id="AuthRegisterXacNhan" name="XacNhanMatKhau" type="password" placeholder="Nhập lại mật khẩu" minlength="6" required />
                            <button type="button" class="auth-toggle" data-toggle-password="#AuthRegisterXacNhan" aria-label="Hiển thị mật khẩu">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        <span class="field-error" data-error-for="XacNhanMatKhau">@Html.ValidationMessageFor(m => m.XacNhanMatKhau)</span>
                    </div>

                    <div class="auth-error">@Html.ValidationSummary(true)</div>

                    <button type="submit" class="auth-btn">Đăng ký ngay</button>
                </form>
            </section>
        </div>
    </div>
</section>

@section Scripts{
    <script src="~/js/Customer/Login.js" asp-append-version="true"></script>
    <script src="~/js/Customer/Register.js" asp-append-version="true"></script>
}






