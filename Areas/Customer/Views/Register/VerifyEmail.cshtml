@{
    ViewData["Title"] = "Xác thực email";
}
<link rel="stylesheet" href="~/css/Customer/Login.css" asp-append-version="true" />

<section class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">Xác thực email</h1>
        <p class="auth-subtitle">@ViewBag.Message</p>
        <div class="auth-switch">
            <a href="/Customer/Login">Đăng nhập</a>
        </div>
    </div>
</section>
